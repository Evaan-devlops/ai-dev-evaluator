APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001

DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_service
VECTOR_DIMENSION=1536

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_ACCESS_TOKEN=

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_ACCESS_TOKEN=

OCR_PROVIDER=
OCR_ACCESS_TOKEN=

MAX_AGENT_STEPS=6
MAX_CONTEXT_TOKENS=8000
DEFAULT_TOP_K=8
LOG_LEVEL=INFO

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
